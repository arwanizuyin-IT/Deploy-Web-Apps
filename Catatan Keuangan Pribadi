        var incData = res.breakdownPendapatan.map(function(x){return x.nominal;});
        if(incData.length === 0) { incLabels = ["Belum Ada"]; incData = [1]; }
        incomeDoughnutChartObj = new Chart(ctxIncDoughnut, {
          type: 'doughnut',
