              { label: 'Keluar', data: res.trend.pengeluaran, borderColor: '#f43f5e', backgroundColor: 'rgba(244,63,94,0.04)', tension: 0.4, fill: true, borderWidth: 2.5 }
            ]
          },
          options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { ticks: { font: { size: 9 } } }, x: { grid: { display: false }, ticks: { font: { size: 9 } } } } }
        });

