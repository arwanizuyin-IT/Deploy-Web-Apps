    function setFormTipe(tipe) {
      state.formTipe = tipe;
      var btnMasuk = document.getElementById('btn-segment-masuk');
      var btnKeluar = document.getElementById('btn-segment-keluar');
      if (tipe === 'Pemasukan') {
        btnMasuk.className = "py-2.5 text-xs font-bold rounded-lg transition text-white bg-[#122b1a]";
        btnKeluar.className = "py-2.5 text-xs font-bold rounded-lg transition text-gray-500 hover:text-gray-800";
      } else {
        btnKeluar.className = "py-2.5 text-xs font-bold rounded-lg transition text-white bg-[#122b1a]";
        btnMasuk.className = "py-2.5 text-xs font-bold rounded-lg transition text-gray-500 hover:text-gray-800";
      }
      renderCategoryFormPills();
    }

    function renderCategoryFormPills() {
      var container = document.getElementById('form-category-pills');
      container.innerHTML = "";
      var filtered = state.categories.filter(function(c) { return c.tipe === state.formTipe; });
      if (filtered.length === 0) {
        container.innerHTML = "<p class='text-xs text-gray-400'>Belum ada pill kategori.</p>";
        return;
      }
      for (var i = 0; i < filtered.length; i++) {
        var cat = filtered[i];
        var pill = document.createElement('button');
        pill.type = "button";
        pill.innerText = cat.nama;
        pill.className = "px-3 py-1.5 text-xs font-medium rounded-full bg-gray-100 border border-gray-200 text-gray-600 transition active:scale-95";
        pill.setAttribute('onclick', "selectCategoryPill(this, '" + cat.nama + "')");
        container.appendChild(pill);
      }
      document.getElementById('form-kategori-val').value = "";
    }

    function selectCategoryPill(element, categoryName) {
      var pills = document.getElementById('form-category-pills').getElementsByTagName('button');
      for (var i = 0; i < pills.length; i++) {
        pills[i].className = "px-3 py-1.5 text-xs font-medium rounded-full bg-gray-100 border border-gray-200 text-gray-600 transition active:scale-95";
      }
      element.className = "px-3 py-1.5 text-xs font-bold rounded-full bg-[#a3e635] text-[#122b1a] border border-[#a3e635]";
      document.getElementById('form-kategori-val').value = categoryName;
    }

    function handleFormSubmit(e) {
      e.preventDefault();
      var maskVal = document.getElementById('form-nominal').value;
      var nominal = parseFloat(maskVal.replace(/\./g, ''));
      var kategori = document.getElementById('form-kategori-val').value;
      var catatan = document.getElementById('form-catatan').value;
      
      if (isNaN(nominal) || nominal <= 0) {
        showToast("Peringatan: Nominal besaran kas tidak valid!");
        return;
      }
      if (!kategori) {
        showToast("Peringatan: Harap pilih salah satu pill kategori!");
        return;
      }
      
      var today = new Date();
      var dateString = ("0" + today.getDate()).slice(-2) + "/" + ("0" + (today.getMonth() + 1)).slice(-2) + "/" + today.getFullYear();
      
      var localTxMock = {
        id: "TX-PENDING",
        tanggal: dateString,
        jam: today.getHours() + ":" + today.getMinutes(),
        tipe: state.formTipe,
        kategori: kategori,
        nominal: nominal,
        catatan: catatan ? catatan : "Transaksi Kas Harian"
      };
      
      state.historyList.unshift(localTxMock);
      if (state.formTipe === 'Pemasukan') {
        state.walletBalance += nominal;
        state.totalPemasukan += nominal;
      } else {
        state.walletBalance -= nominal;
        state.totalPengeluaran += nominal;
      }
      
      updateDashboardUI();
      renderLocalHistoryDOM(false);
      showToast("Berhasil (Optimistic UI): Tersimpan secara lokal!");
      
      document.getElementById('form-nominal').value = "";
      document.getElementById('form-catatan').value = "";
      renderCategoryFormPills();
      switchTab('dashboard');
      
      if (typeof google !== 'undefined') {
        google.script.run.withSuccessHandler(function(res) {
          if (res.success) {
            showToast("Sinkronisasi Selesai: Spreadsheet terupdate.");
            triggerSearch();
            loadReportAndCharts();
          }
        }).saveTransaction(localTxMock.tipe, localTxMock.kategori, localTxMock.nominal, localTxMock.catatan);
      }
    }

    function handleCategorySubmit(e) {
      e.preventDefault();
      var tipe = document.getElementById('kat-form-tipe').value;
      var nama = document.getElementById('kat-form-nama').value.trim();
      if (!nama) return;
      
      if (typeof google !== 'undefined') {
        google.script.run.withSuccessHandler(function(res) {
          if (res.success) {
            state.categories.push({ id: res.id, tipe: res.tipe, nama: res.nama });
            renderCategoryMasterList();
            renderCategoryFormPills();
            document.getElementById('kat-form-nama').value = "";
            showToast("Kategori baru berhasil didaftarkan.");
          }
        }).saveCategory(tipe, nama);
      } else {
        state.categories.push({ id: Date.now().toString(), tipe: tipe, nama: nama });
        renderCategoryMasterList();
        renderCategoryFormPills();
        document.getElementById('kat-form-nama').value = "";
        showToast("Sandbox: Kategori lokal terdaftar.");
      }
    }

    function renderCategoryMasterList() {
      var box = document.getElementById('kat-master-list');
      box.innerHTML = "";
      if (state.categories.length === 0) {
        box.innerHTML = "<p class='text-xs text-gray-400 py-2'>Belum ada data kategori master.</p>";
        return;
      }
      for (var i = 0; i < state.categories.length; i++) {
        var cat = state.categories[i];
        var badge = cat.tipe === 'Pemasukan' ? 'bg-emerald-50 text-emerald-700 border-emerald-200' : 'bg-rose-50 text-rose-700 border-rose-200';
        box.innerHTML += "<div class='flex justify-between items-center bg-gray-50/70 border border-gray-100 px-3 py-2 rounded-xl'>" +
                     "<div class='flex items-center gap-2'>" +
                       "<span class='text-[10px] font-bold px-2 py-0.5 border rounded-md " + badge + "'>" + cat.tipe + "</span>" +
                       "<span class='text-xs font-semibold text-gray-800'>" + cat.nama + "</span>" +
                     "</div>" +
                     "<button onclick='askDeleteCategory(\"" + cat.id + "\")' class='text-gray-400 hover:text-rose-500 p-1 transition'>" +
                       "<svg class='w-3.5 h-3.5' fill='none' stroke='currentColor' stroke-width='2' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' d='M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-4v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16'></path></svg>" +
                     "</button>" +
                   "</div>";
      }
    }

    function askDeleteCategory(id) {
      state.deleteTargetId = id;
      document.getElementById('confirm-modal').classList.remove('hidden');
    }

    function closeConfirmModal() {
      document.getElementById('confirm-modal').classList.add('hidden');
      state.deleteTargetId = null;
    }

    function executeCategoryDelete() {
      var id = state.deleteTargetId;
      if (!id) return;
      if (typeof google !== 'undefined') {
        google.script.run.withSuccessHandler(function(res) {
          if (res.success) {
            state.categories = state.categories.filter(function(c) { return c.id !== id; });
            renderCategoryMasterList();
            renderCategoryFormPills();
            showToast("Kategori berhasil terhapus.");
            closeConfirmModal();
          }
        }).deleteCategory(id);
      } else {
        state.categories = state.categories.filter(function(c) { return c.id !== id; });
        renderCategoryMasterList();
        renderCategoryFormPills();
        showToast("Sandbox: Kategori dihapus.");
        closeConfirmModal();
      }
    }

    function switchTab(tabId) {
      state.currentTab = tabId;
      document.getElementById('page-dashboard').classList.add('hidden');
      document.getElementById('page-histori').classList.add('hidden');
      document.getElementById('page-catat').classList.add('hidden');
      document.getElementById('page-labarugi').classList.add('hidden');
      document.getElementById('page-kategori').classList.add('hidden');
      
      var navIds = ['dashboard', 'histori', 'labarugi', 'kategori'];
      for (var i = 0; i < navIds.length; i++) {
        var el = document.getElementById('nav-' + navIds[i]);
        if (el) {
          el.className = "flex flex-col items-center gap-1 py-1 px-3 text-gray-400 transition active:scale-95";
          var span = el.getElementsByTagName('span')[0];
          if (span) span.className = "text-[9px] font-semibold";
        }
      }
      
      document.getElementById('page-' + tabId).classList.remove('hidden');
      var activeNav = document.getElementById('nav-' + tabId);
      if (activeNav) {
        activeNav.className = "flex flex-col items-center gap-1 py-1 px-3 text-[#122b1a] transition active:scale-95";
        var spanActive = activeNav.getElementsByTagName('span')[0];
        if (spanActive) spanActive.className = "text-[9px] font-bold";
      }
      
      if (tabId === 'labarugi' || tabId === 'dashboard') {
        loadReportAndCharts();
      }
    }

    function showToast(msg) {
      var toast = document.getElementById('toast-msg');
      toast.innerText = msg;
      toast.classList.remove('opacity-0', 'translate-y-2', 'pointer-events-none');
      toast.classList.add('opacity-100', 'translate-y-0');
      setTimeout(function() {
        toast.classList.remove('opacity-100', 'translate-y-0');
        toast.classList.add('opacity-0', 'translate-y-2', 'pointer-events-none');
      }, 3500);
    }
  </script>
